    -- ==========================================
    --  HUB TOGGLE BUTTON (top center, draggable)
    -- ==========================================
    local toggleGui = Instance.new("ScreenGui")
    toggleGui.Name = "SheitsaHubToggle"
    toggleGui.ResetOnSpawn = false
    toggleGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    toggleGui.Parent = CoreGui

    local hubVisible = true

    local function getFluentGui()
        for _, child in ipairs(CoreGui:GetChildren()) do
            if child:IsA("ScreenGui") and child.Name ~= "SheitsaHubToggle" and child.Name ~= "SheitsaKeySystem" then
                return child
            end
        end
        return nil
    end

    local hubToggle = Instance.new("TextButton")
    hubToggle.Size = UDim2.new(0, 44, 0, 44)
    hubToggle.Position = UDim2.new(0.5, -22, 0, 14)
    hubToggle.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
    hubToggle.Text = ""
    hubToggle.BorderSizePixel = 0
    hubToggle.AutoButtonColor = false
    hubToggle.Parent = toggleGui

    Instance.new("UICorner", hubToggle).CornerRadius = UDim.new(0, 11)

    local tStroke = Instance.new("UIStroke", hubToggle)
    tStroke.Color = Color3.fromRGB(190, 190, 200)
    tStroke.Thickness = 1.5

    local tIcon = Instance.new("TextLabel", hubToggle)
    tIcon.Size = UDim2.new(1, 0, 1, 0)
    tIcon.Text = "S2"
    tIcon.TextSize = 14
    tIcon.BackgroundTransparency = 1
    tIcon.TextColor3 = Color3.fromRGB(200, 200, 210)
    tIcon.Font = Enum.Font.GothamBold

    -- Drag + Click for hub toggle (with 5px drag threshold)
    local htDrag, htDragStart, htStartPos, htDidDrag
    hubToggle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            htDrag = true; htDidDrag = false
            htDragStart = input.Position; htStartPos = hubToggle.Position
        end
    end)
    hubToggle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if not htDidDrag then
                hubVisible = not hubVisible
                local fGui = getFluentGui()
                if fGui then fGui.Enabled = hubVisible end
                tIcon.Text = hubVisible and "S2" or "—"
                tStroke.Color = hubVisible and Color3.fromRGB(190, 190, 200) or Color3.fromRGB(80, 80, 90)
                hubToggle.BackgroundColor3 = hubVisible and Color3.fromRGB(12, 12, 16) or Color3.fromRGB(30, 30, 36)
            end
            htDrag = false
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if htDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - htDragStart
            if math.abs(d.X) > 5 or math.abs(d.Y) > 5 then htDidDrag = true end
            hubToggle.Position = UDim2.new(htStartPos.X.Scale, htStartPos.X.Offset + d.X, htStartPos.Y.Scale, htStartPos.Y.Offset + d.Y)
        end
    end)
