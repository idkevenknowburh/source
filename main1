    local function submitKey()
        local input = box.Text
        if input == "" or input:match("^%s*$") then
            status.Text = "⚠  Please enter a key first!"
            status.TextColor3 = Color3.fromRGB(255, 195, 70)
            return
        end
        if isValidKey(input) then
            saveKey(input)
            status.Text = "✓  Valid key! Loading hub..."
            status.TextColor3 = Color3.fromRGB(75, 200, 115)
            submitBtn.Text = "✓  Valid!"
            submitBtn.BackgroundColor3 = Color3.fromRGB(50, 160, 90)
            task.delay(0.8, function()
                local t1 = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
                TweenService:Create(frame, t1, {BackgroundTransparency = 1}):Play()
                TweenService:Create(backdrop, t1, {BackgroundTransparency = 1}):Play()
                task.delay(0.5, function()
                    screen:Destroy()
                    loadHub()
                end)
            end)
        else
            status.Text = "✗  Invalid key. Try again."
            status.TextColor3 = Color3.fromRGB(220, 55, 55)
            TweenService:Create(boxS, TweenInfo.new(0.25), {Color = Color3.fromRGB(220, 55, 55)}):Play()
            task.delay(0.7, function()
                TweenService:Create(boxS, TweenInfo.new(0.25), {Color = Color3.fromRGB(58, 58, 68)}):Play()
            end)
        end
    end

    submitBtn.MouseButton1Click:Connect(submitKey)
    box.FocusLost:Connect(function(enterPressed) if enterPressed then submitKey() end end)
end

