    tl.TextTruncate = Enum.TextTruncate.AtEnd

    local vl = Instance.new("TextLabel", container)
    vl.Size = UDim2.new(0, 50, 0, 18)
    vl.Position = UDim2.new(1, -50, 0, 0)
    vl.BackgroundTransparency = 1
