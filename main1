local function createWindow(title, width, height, sidebarW, guiName)
    sidebarW = sidebarW or 100
    local screen = Instance.new("ScreenGui")
    screen.Name = guiName or "SheitsaHubV2"
    screen.ResetOnSpawn = false
    screen.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
