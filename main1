-- ========== KEY HELPERS ==========
local function isValidKey(input)
    for _, k in ipairs(Keys) do
        if k:lower() == input:lower() then return true end
    end
    return false
end

local function getSavedKey()
    local ok, key = pcall(readfile, KeyFileName)
    if not ok or not key or key == "" then return nil end
    -- Check 1: fingerprint must match current Keys table
    local ok2, fp = pcall(readfile, KeyVerFileName)
    if not ok2 or not fp or fp == "" or fp ~= KeyFingerprint then
        pcall(delfile, KeyFileName)
        pcall(delfile, KeyVerFileName)
        warn("[Sheitsa Hub V2] Key fingerprint mismatch — saved files deleted.")
        return nil
    end
    -- Check 2: saved key must still pass isValidKey against current Keys table
    if not isValidKey(key) then
        pcall(delfile, KeyFileName)
        pcall(delfile, KeyVerFileName)
        warn("[Sheitsa Hub V2] Saved key no longer valid — files deleted.")
        return nil
    end
    warn("[Sheitsa Hub V2] Saved key passed validation (fingerprint: " .. fp .. ")")
    return key
end

local function saveKey(key)
    pcall(writefile, KeyFileName, key)
    pcall(writefile, KeyVerFileName, KeyFingerprint)
end

