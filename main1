    vl.TextColor3 = C.Accent
    vl.TextSize = 12
    vl.Font = Enum.Font.GothamBold
    vl.TextXAlignment = Enum.TextXAlignment.Right

    local track = Instance.new("Frame", container)
    track.Size = UDim2.new(1, 0, 0, 4)
    track.Position = UDim2.new(0, 0, 0, 36)
    track.BackgroundColor3 = C.Border
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(0, 2)

    local pct = (default - min) / (max - min)
    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = C.Accent
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 2)

    local circle = Instance.new("Frame", track)
    circle.Size = UDim2.new(0, 14, 0, 14)
    circle.Position = UDim2.new(pct, -7, 0.5, -7)
    circle.BackgroundColor3 = C.Accent
    circle.BorderSizePixel = 0
    circle.ZIndex = 3
    Instance.new("UICorner", circle).CornerRadius = UDim.new(0, 7)

    local inputArea = Instance.new("TextButton", container)
    inputArea.Size = UDim2.new(1, 0, 0, 24)
    inputArea.Position = UDim2.new(0, 0, 0, 28)
    inputArea.BackgroundTransparency = 1
    inputArea.Text = ""
    inputArea.ZIndex = 4

    local isDragging = false
    local function updateVal(pos)
        local relX = (pos.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
        relX = math.clamp(relX, 0, 1)
        local val = math.floor(min + relX * (max - min) + 0.5)
        val = math.clamp(val, min, max)
        fill.Size = UDim2.new(relX, 0, 1, 0)
        circle.Position = UDim2.new(relX, -7, 0.5, -7)
        vl.Text = tostring(val)
        callback(val)
    end

    inputArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            updateVal(input.Position)
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateVal(input.Position)
        end
    end)
    inputArea.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)
    return container
end

