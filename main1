local KeyVerFileName = "SheitsaHubV2_KeyVer.txt"

-- Auto-compute key fingerprint so ANY change to Keys invalidates saved keys
local function computeKeyFingerprint()
    local str = table.concat(Keys, "|")
    local h = 0
    for i = 1, #str do h = (h * 31 + string.byte(str, i)) % 2147483647 end
    return tostring(h)
end
local KeyFingerprint = computeKeyFingerprint()

