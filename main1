                TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
                TweenService:Create(backdrop, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
                task.delay(0.5, function()
                    screen:Destroy()
                    loadHub()
                end)
            end)
        else
            status.Text = "✗  Invalid key. Try again."
            status.TextColor3 = C.Error
            TweenService:Create(boxStroke, TweenInfo.new(0.25), {Color = C.Error}):Play()
            task.delay(0.7, function()
                TweenService:Create(boxStroke, TweenInfo.new(0.25), {Color = C.Border}):Play()
            end)
        end
    end

    submitBtn.MouseButton1Click:Connect(submitKey)
    box.FocusLost:Connect(function(enter) if enter then submitKey() end end)
end

