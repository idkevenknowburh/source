    Tabs.Misc:AddButton({
        Title = "(FE) Aimbot GUI",
        Description = "Aimbot that works in FE games. Lock-on & team check toggles.",
        Flag = "MiscAimbot",
        Callback = function()
            local Players_ = game:GetService("Players")
            local UIS_ = game:GetService("UserInputService")
            local RunService_ = game:GetService("RunService")
            local localPlayer_ = Players_.LocalPlayer
            local camera_ = workspace.CurrentCamera
            local lockOnActive = false
            local teamCheckActive = false
            local fovRadius = 125

            local sg = Instance.new("ScreenGui")
            sg.Name = "AimbotGui"; sg.Parent = CoreGui

            local function makeBtn(text, y)
                local b = Instance.new("TextButton", sg)
                b.Size = UDim2.new(0, 160, 0, 44); b.Position = UDim2.new(0, 100, 0, y)
                b.Text = text; b.Draggable = true
                b.BackgroundColor3 = C.Card; b.TextColor3 = C.Text
                b.Font = Enum.Font.GothamSemibold; b.TextSize = 13
                Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)
                local s = Instance.new("UIStroke", b); s.Color = C.Border; s.Thickness = 1
                return b
            end

            local toggleBtn_ = makeBtn("Toggle Lock-On", 100)
            local teamBtn_ = makeBtn("Toggle Team Check", 154)

            local fovCircle = Instance.new("ImageLabel", sg)
            fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
            fovCircle.Size = UDim2.new(0, fovRadius * 2, 0, fovRadius * 2)
            fovCircle.Image = "rbxassetid://432312433"
            fovCircle.ImageTransparency = 0.5; fovCircle.ImageColor3 = Color3.new(1, 1, 1)
            fovCircle.BackgroundTransparency = 1; fovCircle.Visible = false; fovCircle.ZIndex = 0

            local function isVisible(tp)
                if not tp.Character or not tp.Character:FindFirstChild("Head") then return false end
                if teamCheckActive and tp.Team == localPlayer_.Team then return false end
                local targetHead = tp.Character.Head.Position
                local dir = (targetHead - camera_.CFrame.Position).unit
                local ray = Ray.new(camera_.CFrame.Position, dir * fovRadius)
                local part, _ = workspace:FindPartOnRay(ray, localPlayer_.Character, false, true)
                if part and part:IsDescendantOf(tp.Character) then
                    local dot = camera_.CFrame.LookVector:Dot(dir)
                    return math.deg(math.acos(dot)) <= (fovRadius / 2)
                end
                return false
            end

            toggleBtn_.MouseButton1Click:Connect(function()
                lockOnActive = not lockOnActive
                toggleBtn_.Text = lockOnActive and "Lock-On ON" or "Toggle Lock-On"
                toggleBtn_.BackgroundColor3 = lockOnActive and Color3.fromRGB(20, 70, 40) or C.Card
                fovCircle.Visible = lockOnActive
            end)

            teamBtn_.MouseButton1Click:Connect(function()
                teamCheckActive = not teamCheckActive
                teamBtn_.Text = teamCheckActive and "Team Check ON" or "Toggle Team Check"
                teamBtn_.BackgroundColor3 = teamCheckActive and Color3.fromRGB(20, 70, 40) or C.Card
            end)

            RunService_.RenderStepped:Connect(function()
                if lockOnActive then
                    for _, p in ipairs(Players_:GetPlayers()) do
                        if p ~= localPlayer_ and isVisible(p) then
                            local head = p.Character.Head
                            local direction = (head.Position - camera_.CFrame.Position).unit
                            camera_.CFrame = CFrame.new(camera_.CFrame.Position, camera_.CFrame.Position + direction * 10)
                            break
                        end
                    end
                end
            end)

            Fluent:Notify({ Title = "Misc", Content = "Aimbot GUI loaded!", Duration = 3 })
        end
    })

