            if not isValidKey(savedKey) then
                status.Text = "Key was changed. Please enter the new key."
                status.TextColor3 = C.Error
                submitBtn.Text = "Submit Key  ->"
                submitBtn.BackgroundColor3 = C.Accent
                pcall(delfile, KeyFileName)
                pcall(delfile, KeyVerFileName)
                return
            end
            submitBtn.Text = "Valid!"
            submitBtn.BackgroundColor3 = Color3.fromRGB(50, 170, 90)
            status.Text = "Authenticated! Loading hub..."
            task.delay(0.6, function()
                TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { BackgroundTransparency = 1 }):Play()
                TweenService:Create(backdrop, TweenInfo.new(0.4), { BackgroundTransparency = 1 }):Play()
                task.delay(0.5, function()
                    screen:Destroy()
                    loadHub()
                end)
            end)
        end)
    end

    getKeyBtn.MouseButton1Click:Connect(function()
        pcall(setclipboard, DiscordLink)
        getKeyBtn.Text = "Copied!"
        status.Text = "Link copied! Join Discord -> #key channel -> copy key"
        status.TextColor3 = C.Accent
        task.delay(2.5, function() getKeyBtn.Text = "Get Key" end)
    end)

    local function submitKey()
        local input = box.Text
        if input == "" or input:match("^%s*$") then
            status.Text = "Please enter a key first!"
            status.TextColor3 = C.Warn
            return
        end
        if isValidKey(input) then
            saveKey(input)
            status.Text = "Valid key! Loading hub..."
            status.TextColor3 = C.Accent
            submitBtn.Text = "Valid!"
            submitBtn.BackgroundColor3 = Color3.fromRGB(50, 170, 90)
            task.delay(0.8, function()
                TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { BackgroundTransparency = 1 }):Play()
                TweenService:Create(backdrop, TweenInfo.new(0.4), { BackgroundTransparency = 1 }):Play()
                task.delay(0.5, function()
                    screen:Destroy()
                    loadHub()
                end)
            end)
        else
            status.Text = "Invalid key. Try again."
            status.TextColor3 = C.Error
            TweenService:Create(boxStroke, TweenInfo.new(0.25), { Color = C.Error }):Play()
            task.delay(0.7, function()
                TweenService:Create(boxStroke, TweenInfo.new(0.25), { Color = C.Border }):Play()
            end)
        end
    end

    submitBtn.MouseButton1Click:Connect(submitKey)
    box.FocusLost:Connect(function(enter) if enter then submitKey() end end)
end

-- ========== LUCKY BLOCK BATTLEGROUNDSSCRIPT (inlined, Custom UI) ==========
function loadLuckyBlockScript()
    local RS = game:GetService("ReplicatedStorage")
    local RunService = game:GetService("RunService")

    local Blocks = {
        Lucky = RS:WaitForChild("SpawnLuckyBlock"),
        Super = RS:WaitForChild("SpawnSuperBlock"),
        Diamond = RS:WaitForChild("SpawnDiamondBlock"),
        Rainbow = RS:WaitForChild("SpawnRainbowBlock"),
        Galaxy = RS:WaitForChild("SpawnGalaxyBlock"),
    }

    local noclipConn = nil
    local stateWS, stateJP, stateNC = 16, 50, false
    local selBlock, selGP = "Lucky Block", "Rainbow Lucky Block"
    local spawnAmt, gpAmt = 5, 3

    local win = createWindow("LBB | Sheitsa Hub V2", 420, 500, 95, "LBB_SheitsaHub")
    local t1 = win:addTab("Blocks")
    local t2 = win:addTab("Universal")
    local t3 = win:addTab("Credits")

    -- Tab 1: Blocks
    makeSectionHeader(t1, "Spawn Blocks")
    makeDropdown(t1, "Block Type", {"Lucky Block", "Super Block", "Diamond Block"}, selBlock, function(v) selBlock = v end)
    makeButton(t1, "Spawn Block", function()
        local m = { ["Lucky Block"] = Blocks.Lucky, ["Super Block"] = Blocks.Super, ["Diamond Block"] = Blocks.Diamond }
        local r = m[selBlock]; if r then r:FireServer() end
    end)
    makeSlider(t1, "Spawn Amount", 1, 50, 5, function(v) spawnAmt = v end)
    makeButton(t1, "Spawn Multiple", function()
        local m = { ["Lucky Block"] = Blocks.Lucky, ["Super Block"] = Blocks.Super, ["Diamond Block"] = Blocks.Diamond }
        local r = m[selBlock]
        if r then for i = 1, math.clamp(spawnAmt, 1, 50) do r:FireServer(); if i < spawnAmt then task.wait(0.1) end end end
    end)

    makeSectionHeader(t1, "VERY OP (Gamepass Blocks)")
    makeDropdown(t1, "Gamepass Block", {"Rainbow Lucky Block", "Galaxy Lucky Block"}, selGP, function(v) selGP = v end)
    makeButton(t1, "Spawn Gamepass Block", function()
        local m = { ["Rainbow Lucky Block"] = Blocks.Rainbow, ["Galaxy Lucky Block"] = Blocks.Galaxy }
        local r = m[selGP]; if r then r:FireServer() end
    end)
    makeSlider(t1, "GP Spawn Amount", 1, 50, 3, function(v) gpAmt = v end)
    makeButton(t1, "Spawn Multiple (GP)", function()
        local m = { ["Rainbow Lucky Block"] = Blocks.Rainbow, ["Galaxy Lucky Block"] = Blocks.Galaxy }
        local r = m[selGP]
        if r then for i = 1, math.clamp(gpAmt, 1, 50) do r:FireServer(); if i < gpAmt then task.wait(0.1) end end end
    end)

    -- Tab 2: Universal
    makeSectionHeader(t2, "Movement")
    makeSlider(t2, "WalkSpeed", 10, 200, 16, function(v)
        stateWS = v
        if player.Character and player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid.WalkSpeed = v end
    end)
    makeSlider(t2, "JumpPower", 10, 500, 50, function(v)
        stateJP = v
        if player.Character and player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid.JumpPower = v end
    end)

    makeSectionHeader(t2, "Physics")
    makeToggle(t2, "NoClip", "Walk through walls", function(on)
        stateNC = on
        if on then
            noclipConn = RunService.Stepped:Connect(function()
                if player.Character then for _, p in ipairs(player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
            end)
        else
            if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
            if player.Character then for _, p in ipairs(player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = true end end end
        end
    end)

    makeSectionHeader(t2, "Tools")
    makeButton(t2, "Infinite Yield", function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source", true))()
    end)

    -- Tab 3: Credits
    makeSectionHeader(t3, "Info")
    makeLabel(t3, "LUCKY BLOCK Battlegrounds")
    makeLabel(t3, "Sheitsa Hub V2")
    makeLabel(t3, "Script made by the Sheitsa Dev Team.")
    makeLabel(t3, "All credits go to Sheitsa Dev Team.")

    makeSectionHeader(t3, "Social")
    makeButton(t3, "Join our Discord", function()
        pcall(setclipboard, DiscordLink)
    end)

    -- Respawn persistence
    player.CharacterAdded:Connect(function(char)
        local h = char:WaitForChild("Humanoid")
        h.WalkSpeed = stateWS; h.JumpPower = stateJP
        task.wait(1)
        if stateNC then
            if noclipConn then noclipConn:Disconnect() end
            noclipConn = RunService.Stepped:Connect(function()
                if player.Character then for _, p in ipairs(player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
            end)
        end
    end)

    -- Toggle button
    createDragToggle("LBB_SheitsaHub", "LB", "LBB")
end

