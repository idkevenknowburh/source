-- ========== DRAGGABLE TOGGLE HELPER ==========
local function createDragToggle(guiName, label, tag)
    local tGui = Instance.new("ScreenGui")
    tGui.Name = tag .. "_Toggle"
    tGui.ResetOnSpawn = false
    tGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    tGui.Parent = CoreGui

    local tBtn = Instance.new("TextButton")
    tBtn.Size = UDim2.new(0, 44, 0, 44)
    tBtn.Position = UDim2.new(0.5, -22, 0, 14)
    tBtn.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
    tBtn.Text = label
    tBtn.TextColor3 = Color3.fromRGB(200, 200, 210)
    tBtn.TextSize = 13
    tBtn.Font = Enum.Font.GothamBold
    tBtn.BorderSizePixel = 0
    tBtn.AutoButtonColor = false
    tBtn.Parent = tGui
    Instance.new("UICorner", tBtn).CornerRadius = UDim.new(0, 11)
    local tStroke = Instance.new("UIStroke", tBtn)
    tStroke.Color = Color3.fromRGB(190, 190, 200)
    tStroke.Thickness = 1.5

    local tbD, tbDS, tbSP, tbDD
    tBtn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            tbD = true; tbDD = false; tbDS = i.Position; tbSP = tBtn.Position
        end
    end)
    tBtn.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            if not tbDD then
                local g = CoreGui:FindFirstChild(guiName)
                if g then
                    g.Enabled = not g.Enabled
                    tStroke.Color = g.Enabled and Color3.fromRGB(190, 190, 200) or Color3.fromRGB(80, 80, 90)
