            local camera_ = workspace.CurrentCamera
            local lockOnActive = false
            local teamCheckActive = false
            local fovRadius = 125

            local sg = Instance.new("ScreenGui")
            sg.Name = "AimbotGui"; sg.Parent = CoreGui

            local function makeBtn(text, y)
                local b = Instance.new("TextButton", sg)
                b.Size = UDim2.new(0, 160, 0, 44); b.Position = UDim2.new(0, 100, 0, y)
                b.Text = text; b.Draggable = true
                b.BackgroundColor3 = C.Card; b.TextColor3 = C.Text
                b.Font = Enum.Font.GothamSemibold; b.TextSize = 13
                Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)
                local s = Instance.new("UIStroke", b); s.Color = C.Border; s.Thickness = 1
                return b
            end

            local toggleBtn_ = makeBtn("Toggle Lock-On", 100)
            local teamBtn_ = makeBtn("Toggle Team Check", 154)

            local fovCircle = Instance.new("ImageLabel", sg)
            fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
            fovCircle.Size = UDim2.new(0, fovRadius * 2, 0, fovRadius * 2)
            fovCircle.Image = "rbxassetid://432312433"
            fovCircle.ImageTransparency = 0.5; fovCircle.ImageColor3 = Color3.new(1, 1, 1)
            fovCircle.BackgroundTransparency = 1; fovCircle.Visible = false; fovCircle.ZIndex = 0

            local function isVisible(tp)
                if not tp.Character or not tp.Character:FindFirstChild("Head") then return false end
                if teamCheckActive and tp.Team == localPlayer_.Team then return false end
                local targetHead = tp.Character.Head.Position
                local dir = (targetHead - camera_.CFrame.Position).unit
                local ray = Ray.new(camera_.CFrame.Position, dir * fovRadius)
                local part, _ = workspace:FindPartOnRay(ray, localPlayer_.Character, false, true)
                if part and part:IsDescendantOf(tp.Character) then
                    local dot = camera_.CFrame.LookVector:Dot(dir)
                    return math.deg(math.acos(dot)) <= (fovRadius / 2)
                end
                return false
            end

            toggleBtn_.MouseButton1Click:Connect(function()
                lockOnActive = not lockOnActive
                toggleBtn_.Text = lockOnActive and "Lock-On ON" or "Toggle Lock-On"
                toggleBtn_.BackgroundColor3 = lockOnActive and Color3.fromRGB(20, 70, 40) or C.Card
                fovCircle.Visible = lockOnActive
            end)

            teamBtn_.MouseButton1Click:Connect(function()
                teamCheckActive = not teamCheckActive
                teamBtn_.Text = teamCheckActive and "Team Check ON" or "Toggle Team Check"
                teamBtn_.BackgroundColor3 = teamCheckActive and Color3.fromRGB(20, 70, 40) or C.Card
            end)

            RunService_.RenderStepped:Connect(function()
                if lockOnActive then
                    for _, p in ipairs(Players_:GetPlayers()) do
                        if p ~= localPlayer_ and isVisible(p) then
                            local head = p.Character.Head
                            local direction = (head.Position - camera_.CFrame.Position).unit
                            camera_.CFrame = CFrame.new(camera_.CFrame.Position, camera_.CFrame.Position + direction * 10)
                            break
                        end
                    end
                end
            end)

            Fluent:Notify({ Title = "Misc", Content = "Aimbot GUI loaded!", Duration = 3 })
        end
    })

    -- ==========================================
    --  SETTINGS TAB
    -- ==========================================
    Tabs.Settings:AddParagraph({
        Title = "Settings",
        Content = "Click the ⚙️ gear icon at the top of the hub to change themes, toggle Acrylic blur, adjust transparency, and more.\n\nCurrent theme: AMOLED (pure dark black)\n\nAll settings are automatically saved by Fluent-Modded."
    })

    Tabs.Settings:AddButton({
        Title = "Reset Configuration",
        Description = "Clears all saved Fluent-Modded settings.",
        Callback = function()
            Fluent:SaveConfiguration(true)
            Fluent:Notify({ Title = "Settings", Content = "Configuration reset! Reloading...", Duration = 3 })
            task.delay(1.5, function()
                Fluent:Unload()
                loadHub()
            end)
        end
    })

    -- ==========================================
    --  CREDITS TAB
    -- ==========================================

    -- Section 1: Sheitsa Team
    Tabs.Credits:AddParagraph({
        Title = "Sheitsa Team",
        Content = "@Sheitsa  [OWNER] [HEAD DEV]\n@boxyy._  [SCRIPT DEV]\n@nomorecoder  [SCRIPT DEV]"
    })

    -- Section 2: UI Library Credit
    Tabs.Credits:AddParagraph({
        Title = "UI Library",
        Content = "Fluent-Modded by StyearX on YouTube\nhttps://github.com/StyearX/Fluent-Modded"
    })

    -- ==========================================
    --  STARTUP NOTIFICATION
    -- ==========================================
    Fluent:Notify({
        Title = "Sheitsa Hub V2",
        Content = "Hub loaded! Press RightControl to minimize.",
        Duration = 5
    })

    -- ==========================================
    --  HUB TOGGLE BUTTON (black & white, square)
    -- ==========================================
    local toggleGui = Instance.new("ScreenGui")
    toggleGui.Name = "SheitsaHubToggle"
    toggleGui.ResetOnSpawn = false
    toggleGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    toggleGui.Parent = CoreGui

    local hubVisible = true

    local function getFluentGui()
        for _, child in ipairs(CoreGui:GetChildren()) do
            if child:IsA("ScreenGui") and child.Name ~= "SheitsaHubToggle" and child.Name ~= "SheitsaKeySystem" then
                return child
            end
        end
        return nil
    end

    local hubToggle = Instance.new("TextButton")
    hubToggle.Size = UDim2.new(0, 44, 0, 44)
    hubToggle.Position = UDim2.new(0, 18, 1, -62)
    hubToggle.BackgroundColor3 = Color3.fromRGB(12, 12, 16)
    hubToggle.Text = ""
    hubToggle.BorderSizePixel = 0
    hubToggle.AutoButtonColor = false
    hubToggle.Parent = toggleGui

    Instance.new("UICorner", hubToggle).CornerRadius = UDim.new(0, 11)

    local tStroke = Instance.new("UIStroke", hubToggle)
    tStroke.Color = Color3.fromRGB(190, 190, 200)
    tStroke.Thickness = 1.5

    local tIcon = Instance.new("TextLabel", hubToggle)
    tIcon.Size = UDim2.new(1, 0, 1, 0)
    tIcon.Text = "S2"
    tIcon.TextSize = 14
    tIcon.BackgroundTransparency = 1
    tIcon.TextColor3 = Color3.fromRGB(200, 200, 210)
    tIcon.Font = Enum.Font.GothamBold

    hubToggle.MouseButton1Click:Connect(function()
        hubVisible = not hubVisible
        local fGui = getFluentGui()
        if fGui then fGui.Enabled = hubVisible end
        tIcon.Text = hubVisible and "S2" or "—"
        tStroke.Color = hubVisible and Color3.fromRGB(190, 190, 200) or Color3.fromRGB(80, 80, 90)
        hubToggle.BackgroundColor3 = hubVisible and Color3.fromRGB(12, 12, 16) or Color3.fromRGB(30, 30, 36)
    end)
end

