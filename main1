    local main = Instance.new("Frame")
    main.Size = UDim2.new(0, width, 0, height)
    main.Position = UDim2.new(0.5, -width / 2, 0.5, -height / 2)
    main.BackgroundColor3 = C.BG
    main.BorderSizePixel = 0
    main.Parent = screen
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)
    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Color = C.Border
    mainStroke.Thickness = 1

    -- Title bar
    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1, 0, 0, 42)
    titleBar.BackgroundColor3 = C.TitleBar
    titleBar.BorderSizePixel = 0
    titleBar.Parent = main
    Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0, 12)
    local tbCover = Instance.new("Frame", titleBar)
    tbCover.Size = UDim2.new(1, 0, 0, 14)
    tbCover.Position = UDim2.new(0, 0, 1, -14)
    tbCover.BackgroundColor3 = C.TitleBar
    tbCover.BorderSizePixel = 0

    local titleText = Instance.new("TextLabel", titleBar)
    titleText.Size = UDim2.new(1, -80, 1, 0)
    titleText.Position = UDim2.new(0, 16, 0, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = title
    titleText.TextColor3 = C.Text
    titleText.TextSize = 14
    titleText.Font = Enum.Font.GothamBold
    titleText.TextXAlignment = Enum.TextXAlignment.Left
    titleText.TextTruncate = Enum.TextTruncate.AtEnd

    local closeBtn = Instance.new("TextButton", titleBar)
    closeBtn.Size = UDim2.new(0, 26, 0, 26)
    closeBtn.Position = UDim2.new(1, -34, 0, 8)
    closeBtn.BackgroundColor3 = C.Close
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = Color3.new(1, 1, 1)
    closeBtn.TextSize = 12
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.BorderSizePixel = 0
    closeBtn.AutoButtonColor = false
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 8)

    -- Drag
    local dragging, dragStart, startPos
    local dragConn
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = main.Position
        end
    end)
    titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    dragConn = UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local d = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)

    closeBtn.MouseButton1Click:Connect(function()
        if dragConn then dragConn:Disconnect() end
        screen:Destroy()
    end)

    -- Sidebar
    local sidebar = Instance.new("Frame")
    sidebar.Size = UDim2.new(0, sidebarW, 1, -42)
    sidebar.Position = UDim2.new(0, 0, 0, 42)
    sidebar.BackgroundColor3 = C.Card
    sidebar.BorderSizePixel = 0
    sidebar.Parent = main
    local sideBorder = Instance.new("Frame", sidebar)
    sideBorder.Size = UDim2.new(0, 1, 1, 0)
    sideBorder.Position = UDim2.new(1, -1, 0, 0)
    sideBorder.BackgroundColor3 = C.Border
    sideBorder.BorderSizePixel = 0

    -- Content
    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1, -sidebarW, 1, -42)
    content.Position = UDim2.new(0, sidebarW, 0, 42)
    content.BackgroundTransparency = 1
    content.ScrollBarThickness = 4
    content.ScrollBarImageColor3 = Color3.fromRGB(40, 40, 55)
    content.AutomaticCanvasSize = Enum.AutomaticSize.Y
    content.CanvasSize = UDim2.new(0, 0, 0, 0)
    content.Parent = main
    local contentPad = Instance.new("UIPadding", content)
    contentPad.PaddingAll = UDim.new(0, 14)
    local contentList = Instance.new("UIListLayout", content)
    contentList.SortOrder = Enum.SortOrder.LayoutOrder
    contentList.Padding = UDim.new(0, 5)

    -- Tab system
    local tabPages = {}
    local tabButtons = {}
    local currentTab = nil
    local tabIdx = 0

    local function addTab(name)
        tabIdx = tabIdx + 1
        local page = Instance.new("Frame")
        page.Size = UDim2.new(1, 0, 0, 0)
        page.BackgroundTransparency = 1
        page.AutomaticSize = Enum.AutomaticSize.Y
        page.Visible = false
        page.Parent = content
        tabPages[name] = page

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -8, 0, 34)
        btn.BackgroundColor3 = Color3.new(0, 0, 0)
        btn.BackgroundTransparency = 1
        btn.Text = name
        btn.TextColor3 = C.TextSub
        btn.TextSize = 11
        btn.Font = Enum.Font.GothamMedium
        btn.BorderSizePixel = 0
        btn.AutoButtonColor = false
        btn.LayoutOrder = tabIdx
        btn.Parent = sidebar

        local indicator = Instance.new("Frame")
        indicator.Size = UDim2.new(0, 2, 0.6, 0)
        indicator.Position = UDim2.new(0, 0, 0.2, 0)
        indicator.BackgroundColor3 = C.Accent
        indicator.BorderSizePixel = 0
        indicator.Visible = false
        indicator.Parent = btn
        Instance.new("UICorner", indicator).CornerRadius = UDim.new(0, 1)

        tabButtons[name] = { btn = btn, indicator = indicator }

        btn.MouseButton1Click:Connect(function()
            for _, p in pairs(tabPages) do p.Visible = false end
            page.Visible = true
            for n, t in pairs(tabButtons) do
                if n == name then
                    t.btn.BackgroundColor3 = C.CardHover
                    t.btn.BackgroundTransparency = 0
                    t.btn.TextColor3 = C.Text
                    t.indicator.Visible = true
                else
                    t.btn.BackgroundColor3 = Color3.new(0, 0, 0)
                    t.btn.BackgroundTransparency = 1
                    t.btn.TextColor3 = C.TextSub
                    t.indicator.Visible = false
                end
            end
            currentTab = name
        end)

        if not currentTab then
            btn.BackgroundColor3 = C.CardHover
            btn.BackgroundTransparency = 0
            btn.TextColor3 = C.Text
            indicator.Visible = true
            page.Visible = true
            currentTab = name
        end

        return page
    end

    return { addTab = addTab, gui = screen, main = main }
end

