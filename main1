            fovCircle.AnchorPoint = Vector2.new(0.5, 0.5)
            fovCircle.Size = UDim2.new(0, fovRadius * 2, 0, fovRadius * 2)
            fovCircle.Image = "rbxassetid://432312433"
            fovCircle.ImageTransparency = 0.5
            fovCircle.ImageColor3 = Color3.new(1, 1, 1)
            fovCircle.BackgroundTransparency = 1
            fovCircle.Visible = false
            fovCircle.ZIndex = 0

            local function isPlayerVisible(targetPlayer)
                if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("Head") then return false end
                if teamCheckActive and targetPlayer.Team == localPlayer_.Team then return false end
                local targetHead = targetPlayer.Character.Head.Position
                local dir = (targetHead - camera_.CFrame.Position).unit
                local ray = Ray.new(camera_.CFrame.Position, dir * fovRadius)
                local part, _ = game:GetService("Workspace"):FindPartOnRay(ray, localPlayer_.Character, false, true)
                if part and part:IsDescendantOf(targetPlayer.Character) then
                    local dot = camera_.CFrame.LookVector:Dot(dir)
                    local angle = math.deg(math.acos(dot))
                    return angle <= (fovRadius / 2)
                end
                return false
            end

            toggleBtn_.MouseButton1Click:Connect(function()
                lockOnActive = not lockOnActive
                toggleBtn_.Text = lockOnActive and "Lock-On ON" or "Toggle Lock-On"
                toggleBtn_.BackgroundColor3 = lockOnActive and Color3.fromRGB(75, 200, 115) or Color3.fromRGB(30, 30, 36)
                fovCircle.Visible = lockOnActive
            end)

            teamBtn_.MouseButton1Click:Connect(function()
                teamCheckActive = not teamCheckActive
                teamBtn_.Text = teamCheckActive and "Team Check ON" or "Toggle Team Check"
                teamBtn_.BackgroundColor3 = teamCheckActive and Color3.fromRGB(75, 200, 115) or Color3.fromRGB(30, 30, 36)
            end)

            RunService_.RenderStepped:Connect(function()
                if lockOnActive then
                    for _, p in ipairs(Players_:GetPlayers()) do
                        if p ~= localPlayer_ and isPlayerVisible(p) then
                            local head = p.Character.Head
                            local direction = (head.Position - camera_.CFrame.Position).unit
                            camera_.CFrame = CFrame.new(camera_.CFrame.Position, camera_.CFrame.Position + direction * 10)
                            break
                        end
                    end
                end
            end)

            Fluent:Notify({ Title = "Misc", Content = "Aimbot GUI loaded!", Duration = 3 })
        end
    })

