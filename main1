-- ========== KEY HELPERS ==========
local function isValidKey(input)
    for _, k in ipairs(Keys) do
        if k:lower() == input:lower() then return true end
    end
    return false
end

local function getSavedKey()
    local ok, key = pcall(readfile, KeyFileName)
    if not ok then return nil end
    -- Check if key version matches — if you changed keys, force re-auth
    local ok2, ver = pcall(readfile, KeyVerFileName)
    if not ok2 or tonumber(ver) ~= KeyVersion then
        pcall(delfile, KeyFileName)
        pcall(delfile, KeyVerFileName)
        return nil
    end
    return key
end

local function saveKey(key)
    pcall(writefile, KeyFileName, key)
    pcall(writefile, KeyVerFileName, tostring(KeyVersion))
end

